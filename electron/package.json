{
  "name": "mychat-desktop",
  "version": "1.0.0",
  "description": "MyChat Desktop - AI Chat with Local LLM",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "concurrently \"npm run web\" \"wait-on http://localhost:8081 && electron .\"",
    "electron:build": "npm run build:web && electron-builder",
    "electron:build:mac": "npm run build:web && electron-builder --mac",
    "electron:build:win": "npm run build:web && electron-builder --win"
  },
  "author": "MyChat",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mychat.desktop",
    "productName": "MyChat",
    "directories": {
      "output": "desktop-build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "llama-binaries/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "extraResources": [
        {
          "from": "llama-binaries/mac",
          "to": "llama-binaries",
          "filter": ["**/*"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "extraResources": [
        {
          "from": "llama-binaries/win",
          "to": "llama-binaries",
          "filter": ["**/*"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
