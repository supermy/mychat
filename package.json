{
  "name": "mychat",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "engine:download": "node scripts/download-engines.js all",
    "engine:check": "node scripts/download-engines.js check",
    "model:download": "node scripts/download-model.js",
    "model:check": "node scripts/download-model.js check",
    "electron:dev": "concurrently \"npm run web\" \"wait-on http://localhost:8081 && cross-env NODE_ENV=development electron ./electron/main.js\"",
    "electron:build": "npm run build:web && electron-builder",
    "electron:build:mac": "npm run engine:download && npm run model:download && npm run build:web && electron-builder --mac",
    "electron:build:win": "npm run engine:download && npm run model:download && npm run build:web && electron-builder --win",
    "electron:build:all": "npm run engine:download && npm run model:download && npm run build:web && electron-builder --mac --win",
    "postinstall": "node scripts/download-engines.js check && node scripts/download-model.js check"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "^0.5.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "adm-zip": "^0.5.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tar": "^7.5.10",
    "typescript": "~5.9.2",
    "wait-on": "^7.2.0"
  },
  "private": true,
  "author": "MyChat Team",
  "description": "Cross-platform AI Chat Application with Local LLM Support",
  "build": {
    "appId": "com.mychat.desktop",
    "productName": "MyChat",
    "directories": {
      "output": "desktop-build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "scripts/download-engines.js",
      "scripts/download-model.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "engine-binaries/${os}",
        "to": "engine-binaries",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "default-model",
        "to": "default-model",
        "filter": [
          "**/*.gguf"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
